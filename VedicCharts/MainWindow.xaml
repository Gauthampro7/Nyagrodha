<Window x:Class="VedicCharts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VedicCharts"
        xmlns:controls="clr-namespace:VedicCharts.Controls"
        mc:Ignorable="d"
        Title="Nyagrodha" Height="600" Width="720"
        MinHeight="520" MinWidth="640"
        FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource WindowBackgroundBrush}">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open…" Click="OpenMenuItem_Click" />
                <MenuItem Header="_Save…" Click="SaveMenuItem_Click" />
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Keyboard _shortcuts" Click="KeyboardShortcutsMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Expander x:Name="BirthDataExpander" Header="Birth data" IsExpanded="True" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Date:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                            <DatePicker x:Name="BirthDatePicker" Grid.Column="1" Margin="0,0,0,6"/>
                            <TextBlock Text="Time (HH:mm):" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,6"/>
                            <TextBox x:Name="BirthTimeBox" Grid.Row="1" Grid.Column="1" Padding="4,2" Margin="0,0,0,6" MaxLength="5" ToolTip="24-hour, e.g. 14:30"/>
                            <TextBlock Text="Ayanamsa:" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="AyanamsaCombo" Grid.Row="2" Grid.Column="1" Padding="4,2" MinWidth="180" IsReadOnly="True" DisplayMemberPath="DisplayText"/>
                        </Grid>
                    </Expander>

                    <Expander x:Name="BirthPlaceExpander" Header="Birth place" IsExpanded="True" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                            <TextBox x:Name="PlaceSearchBox" Grid.Column="1" Padding="4,2" Margin="0,0,0,6"
                                     KeyUp="PlaceSearchBox_KeyUp"/>
                            <ListBox x:Name="PlaceResultsList" Grid.Row="1" Grid.ColumnSpan="2" MaxHeight="120" Margin="0,0,0,6"
                                     SelectionChanged="PlaceResultsList_SelectionChanged" DisplayMemberPath="DisplayText"/>
                            <TextBlock Grid.Row="2" Text="Coordinates:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="CoordsText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Text="—" Foreground="Gray" TextWrapping="Wrap" />
                            <TextBlock x:Name="LocationDbCue" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,6,0,0" FontSize="11" Foreground="#888" Text="" />
                        </Grid>
                    </Expander>

                    <GroupBox Header="Chart settings" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Style:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                            <ComboBox x:Name="ChartStyleCombo" Grid.Column="1" Padding="4,2" Margin="0,0,0,6" MinWidth="180" IsReadOnly="True"/>
                            <TextBlock Text="Chart:" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="ChartTypeCombo" Grid.Row="1" Grid.Column="1" Padding="4,2" MinWidth="180" IsReadOnly="True"/>
                        </Grid>
                    </GroupBox>

                    <WrapPanel Margin="0,4,0,8">
                        <Button x:Name="CalculateButton"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Content="Create chart (Ctrl+Enter)"
                                Click="CalculateButton_Click"
                                Padding="16,8"
                                Margin="0,0,8,0"/>
                        <Button Content="Clear (Ctrl+Shift+C)"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Click="ClearButton_Click"
                                Padding="16,8"/>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>

            <GroupBox Grid.Column="2" Header="Output" Padding="10">
                <TabControl>
                    <TabItem Header="Chart">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6" VerticalAlignment="Center">
                                <Button x:Name="CopyChartImageButton"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Content="Copy chart image"
                                        Click="CopyChartImageButton_Click"
                                        Padding="10,4"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="CopyChartTextButton"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Content="Copy chart as text"
                                        Click="CopyChartTextButton_Click"
                                        Padding="10,4"
                                        Margin="0,0,12,0"/>
                                <TextBlock x:Name="CopyStatusText"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Text=""/>
                            </StackPanel>

                            <Border x:Name="ChartContainerBorder" Grid.Row="1"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="4" Padding="6" Margin="0,0,2,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox x:Name="Slot0ChartTypeCombo" Grid.Row="0" Margin="0,0,0,4" MinWidth="140" IsReadOnly="True" DisplayMemberPath="DisplayText" SelectionChanged="SlotChartType_SelectionChanged"/>
                                            <controls:IndianChartControl x:Name="IndianChartSlot0" Grid.Row="1" ChartStyle="South"/>
                                        </Grid>
                                    </Border>
                                    <GridSplitter Grid.Row="0" Grid.Column="1" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.RowSpan="3" Background="Transparent" ShowsPreview="False" ResizeDirection="Columns"/>
                                    <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="4" Padding="6" Margin="2,0,0,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox x:Name="Slot1ChartTypeCombo" Grid.Row="0" Margin="0,0,0,4" MinWidth="140" IsReadOnly="True" DisplayMemberPath="DisplayText" SelectionChanged="SlotChartType_SelectionChanged"/>
                                            <controls:IndianChartControl x:Name="IndianChartSlot1" Grid.Row="1" ChartStyle="South"/>
                                        </Grid>
                                    </Border>

                                    <GridSplitter Grid.Row="1" Grid.Column="0" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Grid.ColumnSpan="3" Background="Transparent" ShowsPreview="False" ResizeDirection="Rows"/>
                                    <Border Grid.Row="2" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="4" Padding="6" Margin="0,2,2,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox x:Name="Slot2ChartTypeCombo" Grid.Row="0" Margin="0,0,0,4" MinWidth="140" IsReadOnly="True" DisplayMemberPath="DisplayText" SelectionChanged="SlotChartType_SelectionChanged"/>
                                            <controls:IndianChartControl x:Name="IndianChartSlot2" Grid.Row="1" ChartStyle="South"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="4" Padding="6" Margin="2,2,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox x:Name="Slot3ChartTypeCombo" Grid.Row="0" Margin="0,0,0,4" MinWidth="140" IsReadOnly="True" DisplayMemberPath="DisplayText" SelectionChanged="SlotChartType_SelectionChanged"/>
                                            <controls:IndianChartControl x:Name="IndianChartSlot3" Grid.Row="1" ChartStyle="South"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="List">
                        <Grid>
                            <ListBox x:Name="ChartListBox" DisplayMemberPath="DisplayText" FontFamily="Consolas" FontSize="14"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
