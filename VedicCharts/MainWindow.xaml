<Window x:Class="VedicCharts.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VedicCharts"
        mc:Ignorable="d"
        Title="Vedic Birth Chart" Height="600" Width="700"
        MinHeight="500" MinWidth="600">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Birth data" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Date:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <DatePicker x:Name="BirthDatePicker" Grid.Column="1" Margin="0,0,0,6"/>
                <TextBlock Text="Time (HH:mm):" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="BirthTimeBox" Grid.Row="1" Grid.Column="1" Padding="4,2" Margin="0,0,0,6" MaxLength="5" ToolTip="24-hour, e.g. 14:30"/>
                <TextBlock Text="Ayanamsa:" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="AyanamsaCombo" Grid.Row="2" Grid.Column="1" Padding="4,2" MinWidth="180" IsReadOnly="True" DisplayMemberPath="DisplayText"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Birth place" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="PlaceSearchBox" Grid.Column="1" Padding="4,2" Margin="0,0,0,6"
                         KeyUp="PlaceSearchBox_KeyUp"/>
                <ListBox x:Name="PlaceResultsList" Grid.Row="1" Grid.ColumnSpan="2" MaxHeight="120" Margin="0,0,0,6"
                         SelectionChanged="PlaceResultsList_SelectionChanged" DisplayMemberPath="DisplayText"/>
                <TextBlock Grid.Row="2" Text="Coordinates:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="CoordsText" VerticalAlignment="Center" Text="—" Foreground="Gray"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="CalculateButton" Content="Create chart" Click="CalculateButton_Click" Padding="16,8" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <Button Content="Clear" Click="ClearButton_Click" Padding="16,8"/>
        </StackPanel>

        <GroupBox Grid.Row="3" Header="Birth chart (planets in zodiac)" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="ChartListBox" DisplayMemberPath="DisplayText" FontFamily="Consolas" FontSize="14"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
