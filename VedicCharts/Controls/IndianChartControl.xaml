<UserControl x:Class="VedicCharts.Controls.IndianChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:VedicCharts.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="450">
    <Grid>
        <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
            <Grid Width="420" Height="420">
                <ContentControl Content="{Binding RelativeSource={RelativeSource AncestorType=local:IndianChartControl}, Path=View}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type local:SouthChartView}">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="4" Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border MinWidth="80" MinHeight="60">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="#33000000"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Padding" Value="6"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Padding" Value="0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock Text="{Binding SignLabel}"
                                                                   FontWeight="SemiBold"
                                                                   DockPanel.Dock="Left"
                                                                   Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding HouseLabel}"
                                                                   Foreground="#88000000"
                                                                   DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding PlanetsText}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Top"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type local:NorthChartView}">
                            <Grid>
                                <!-- North Indian diamond: outer diamond, cross, inner square, diagonals to inner corners -->
                                <Canvas Width="420" Height="420">
                                    <!-- Outer diamond (square rotated 45°) -->
                                    <Polygon Points="210,10 410,210 210,410 10,210"
                                             Stroke="#33000000" StrokeThickness="2" Fill="Transparent"/>
                                    <!-- Cross through centre: vertical and horizontal -->
                                    <Line X1="210" Y1="10" X2="210" Y2="410" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="10" Y1="210" X2="410" Y2="210" Stroke="#33000000" StrokeThickness="1"/>
                                    <!-- Inner square (edge midpoints of outer diamond) -->
                                    <Line X1="110" Y1="110" X2="310" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="310" Y1="110" X2="310" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="310" Y1="310" X2="110" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="110" Y1="310" X2="110" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                    <!-- Diagonals from outer corners to inner corners -->
                                    <Line X1="210" Y1="10" X2="110" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="210" Y1="10" X2="310" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="410" Y1="210" X2="310" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="410" Y1="210" X2="310" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="210" Y1="410" X2="310" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="210" Y1="410" X2="110" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="10" Y1="210" X2="110" Y2="310" Stroke="#33000000" StrokeThickness="1"/>
                                    <Line X1="10" Y1="210" X2="110" Y2="110" Stroke="#33000000" StrokeThickness="1"/>
                                </Canvas>

                                <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas Width="420" Height="420"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#33000000" BorderThickness="1" Padding="6" Background="#0A000000" Width="120" Height="72">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <DockPanel LastChildFill="True">
                                                        <TextBlock Text="{Binding HouseLabel}" FontWeight="SemiBold" DockPanel.Dock="Left" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding SignLabel}" Foreground="#88000000" DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1" Text="{Binding PlanetsText}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>

