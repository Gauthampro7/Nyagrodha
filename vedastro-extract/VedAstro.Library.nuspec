<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>VedAstro.Library</id>
    <version>1.2.0</version>
    <title>VedAstro</title>
    <authors>VedAstro</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://vedastro.org/</projectUrl>
    <description>Powerful open-source vedic astrology calculator library</description>
    <releaseNotes>minor non-breaking fixes</releaseNotes>
    <copyright>Copyright (c) 2014-2023 VedAstro</copyright>
    <tags>astrology vedic calculator muhurtha dasa bhukti antaram horoscope match kuta planet longitudes zodiac sign constellation</tags>
    <repository type="git" url="https://github.com/VedAstro/VedAstro" />
    <dependencies>
      <group targetFramework="net7.0">
        <dependency id="ByteSize" version="2.1.1" exclude="Build,Analyzers" />
        <dependency id="Google.Apis" version="1.51.0" exclude="Build,Analyzers" />
        <dependency id="Google.Apis.Auth" version="1.51.0" exclude="Build,Analyzers" />
        <dependency id="Google.Apis.Calendar.v3" version="1.51.0.2237" exclude="Build,Analyzers" />
        <dependency id="Google.Apis.Core" version="1.51.0" exclude="Build,Analyzers" />
        <dependency id="Microsoft.AspNetCore.Components.WebAssembly" version="6.0.11" exclude="Build,Analyzers" />
        <dependency id="Microsoft.Extensions.Caching.Memory" version="6.0.1" exclude="Build,Analyzers" />
        <dependency id="Microsoft.JSInterop" version="6.0.11" exclude="Build,Analyzers" />
        <dependency id="SwissEphNet" version="2.8.0.2" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>